---
import ServerStatus from "../islands/ServerStatus";
import CopyIpButton from "../islands/CopyIpButton";
import SectionHeading from "../ui/SectionHeading.astro";
---

<section id="estado" class="relative px-4 py-24 sm:px-6 sm:py-32">
  <div class="mx-auto max-w-xl">
    <SectionHeading eyebrow="En vivo" title="Estado del servidor" />

    <div class="reveal mt-12">
      <ServerStatus client:visible />
    </div>

    <div class="reveal mt-6 flex justify-center">
      <CopyIpButton client:visible />
    </div>
  </div>
</section>

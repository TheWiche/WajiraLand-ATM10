---
import { FEATURES } from "../../data/features";
import FeatureCard from "../ui/FeatureCard.astro";
import SectionHeading from "../ui/SectionHeading.astro";
---

<section id="caracteristicas" class="relative px-4 py-24 sm:px-6 sm:py-32">
  <div class="mx-auto max-w-6xl">
    <SectionHeading
      eyebrow="Qué te espera"
      title="Un modpack, cinco pilares"
      description="Otherworld [Dungeons & Dragons] reúne exploración, magia y combate de fantasía inspirados en D&D 5e. Esto es lo que encontrarás en Wajira Land."
    />

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {FEATURES.map((feature, index) => <FeatureCard {...feature} index={index} />)}
    </div>
  </div>
</section>

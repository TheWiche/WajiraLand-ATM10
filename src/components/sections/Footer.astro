---
import { Image } from "astro:assets";
import logo from "../../assets/logo.png";
import { SITE, SOCIAL, GITHUB } from "../../config/site";
import Icon from "../ui/Icon.astro";
import VersionBadge from "../islands/VersionBadge";

const currentYear = new Date().getFullYear();
---

<footer class="relative border-t border-mist-200/10 px-4 py-12 sm:px-6">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-8 text-center sm:flex-row sm:justify-between sm:text-left">
    <div class="flex flex-col items-center gap-3 sm:items-start">
      <a href="#hero" class="flex items-center gap-2">
        <Image src={logo} alt="Wajira Land" width={28} height={26} class="h-7 w-auto" />
        <span class="font-display text-base font-semibold text-mist-50">
          Wajira<span class="text-emerald-glow">Land</span>
        </span>
      </a>
      <p class="max-w-xs text-sm text-mist-400">
        Servidor comunitario de Minecraft. No afiliado a Mojang ni a Microsoft.
      </p>
    </div>

    <div class="flex flex-col items-center gap-4 sm:items-end">
      <div class="flex items-center gap-3">
        <a
          href={SOCIAL.discord}
          target="_blank"
          rel="noreferrer"
          aria-label="Discord"
          class="flex size-10 items-center justify-center rounded-xl border border-mist-200/15 text-mist-200 transition-all duration-200 hover:border-emerald-glow/40 hover:text-emerald-glow"
        >
          <Icon name="discord" class="size-5" />
        </a>
        <a
          href={GITHUB.repoUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
          class="flex size-10 items-center justify-center rounded-xl border border-mist-200/15 text-mist-200 transition-all duration-200 hover:border-emerald-glow/40 hover:text-emerald-glow"
        >
          <Icon name="github" class="size-5" />
        </a>
      </div>
      <VersionBadge client:visible />
      <p class="text-xs text-mist-400">© {currentYear} {SITE.name}. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
